# --- Python ---
__pycache__/
*.py[cod]
.venv/
.pytest_cache/
*.egg-info/

# --- Node / web build (FastAPI serves a prebuilt bundle; sources are tracked) ---
node_modules/
dist/
tool/webapp/dist/

# --- Rust / Go / native build outputs ---
target/
**/target/

# --- Per-target engine artifacts (M5 bootstrap; #63 worktree-local go/rust caches) ---
.oss-venv/
.oss-bootstrap.json
.oss-go/
.oss-cargo/

# --- Review + scratch intermediates ---
.reviews/
.reviews-local/
.adopt-src/

# --- Working-copy / cloned targets (NOT committed). The engine needs each target to BE a
#     git repo (for git apply / pristine), so committing one as content/gitlinks is broken.
#     Tracked instead: targets/_meta sidecars, cell-1 findings, and — for the synthetic
#     demo targets — their SOURCE under targets/_src/ (#56). `make targets` (tool/
#     demo_targets.py) materializes the gitignored working copies below from _src. ---
/targets/jackson-databind/
/targets/headroom/
cell-1/backtest/worktrees/
/targets/gobug-demo/
/targets/jsbug-demo/
/targets/pybug-demo/
/targets/rustbug-demo/
/targets/rustws-demo/

# --- transient runtime state (regenerated by run_store / discover / schedule; not source) ---
cell-1/.runs.db
cell-1/.runs.db-shm
cell-1/.runs.db-wal
cell-1/.pipeline.lock
cell-1/.locks/
cell-1/hunt/discovery-queue.yaml
cell-1/hunt/scheduler-state.yaml
cell-1/hunt/VULN-FINDINGS-*.json
cell-1/hunt/STOP
# --- nested-git synthetic target (like the other *-demo; portability = follow-on) ---
/targets/pysrc-demo/
